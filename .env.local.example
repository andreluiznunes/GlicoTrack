# Copie este arquivo para .env.local e preencha com os valores do seu projeto
# Supabase (Project Settings → API no painel).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL onde o app roda — usada para montar os links de confirmação de e-mail
# e redefinição de senha. Trocar pelo domínio da Vercel em produção.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
